# Supabase (project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by import scripts + server actions. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# IGDB via Twitch (dev.twitch.tv → Applications → register + get client id/secret)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Optional — BGG username for future /admin/sync collection pulls
BGG_USERNAME=

# BGG XML API2 requires a registered application token as of 2026.
# Register at https://boardgamegeek.com/applications (approval can take up to a week).
BGG_AUTH_TOKEN=

# Ludopedia personal API token — instant, no approval wait.
# Generate at https://ludopedia.com.br/configuracoes/api (while logged in).
# Used as a fallback/alternative to BGG for Brazilian / Portuguese board game data.
LUDOPEDIA_TOKEN=
