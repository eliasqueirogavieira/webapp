# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# personal CSV exports (don't commit your data)
/data

# Claude Code local state
/.claude

# Playwright MCP debug artifacts
/.playwright-mcp

# Local screenshots from manual UI testing (root-level only;
# real assets live under public/ or src/)
/*.png
/*.jpg
/*.jpeg

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
